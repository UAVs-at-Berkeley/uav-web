---
interface Logo {
  name: string;
  image: string;
  link: string;
}

interface Props {
  logos: Logo[];
}

const { logos } = Astro.props;
---

<section class="logo-gallery" aria-label="Sponsor logos">
  {
    logos.map((logo) => (
      <a href={logo.link} target="_blank" rel="noreferrer" aria-label={logo.name}>
        <img src={logo.image} alt={logo.name} loading="lazy" />
      </a>
    ))
  }
</section>

<style>
  .logo-gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 220px));
    justify-content: center;
    align-items: center;
    gap: 1rem 1.25rem;
  }

  .logo-gallery a {
    width: 100%;
    aspect-ratio: 16 / 10;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.7rem;
    text-decoration: none;
    transition: opacity 180ms ease;
  }

  .logo-gallery a:hover {
    opacity: 0.85;
  }

  .logo-gallery img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
    object-position: center;
  }

  @media (max-width: 700px) {
    .logo-gallery {
      gap: 0.8rem;
    }

    .logo-gallery a {
      aspect-ratio: 16 / 10;
      padding: 0.6rem;
    }
  }
</style>
