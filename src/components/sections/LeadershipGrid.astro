---
interface Member {
  name: string;
  title: string;
  image: string;
}

interface Props {
  members: Member[];
}

const { members } = Astro.props;
---

<section class="leadership-grid">
  {
    members.map((member) => (
      <article>
        <img src={member.image} alt={member.name} loading="lazy" />
        <h3>{member.name}</h3>
        <p>{member.title}</p>
      </article>
    ))
  }
</section>

<style>
  .leadership-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
    gap: 1rem;
  }

  article {
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    padding: 1rem;
    background: #ffffff;
  }

  img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 0.5rem;
    border: 1px solid #e5e7eb;
  }

  h3 {
    margin: 0.7rem 0 0.25rem;
  }

  p {
    margin: 0;
    color: #4b5563;
  }
</style>
