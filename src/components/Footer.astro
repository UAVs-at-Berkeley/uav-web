---
import { MessageCircle, Instagram, Linkedin, Youtube } from "lucide-react";

const baseUrl = import.meta.env.BASE_URL;

const sitemapLinks = [
  { href: baseUrl, label: "Home" },
  { href: `${baseUrl}projects`, label: "Projects" },
  { href: `${baseUrl}sponsors`, label: "Sponsors" },
  { href: `${baseUrl}contact`, label: "Contact" },
  { href: `${baseUrl}join`, label: "Join" }
];

const socialLinks = [
  { href: "https://www.instagram.com/uavs_berkeley/", label: "Instagram", Icon: Instagram },
  { href: "https://www.linkedin.com/company/uavsatberkeley", label: "LinkedIn", Icon: Linkedin },
  { href: "https://www.youtube.com/@uavsatberkeley2508", label: "YouTube", Icon: Youtube },
  { href: "https://discord.gg/UfFhAbaJnU", label: "Discord", Icon: MessageCircle },
];
---

<footer class="site-footer">
  <div class="inner">
    <div class="brand-block">
      <p class="brand-name">UAVs@Berkeley</p>
      <p class="brand-tagline"></p>
    </div>

    <div class="footer-nav">
      <section aria-labelledby="footer-sitemap-heading">
        <h2 id="footer-sitemap-heading" class="section-title">Sitemap</h2>
        <ul class="link-list">
          {sitemapLinks.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))}
        </ul>
      </section>

      <section aria-labelledby="footer-social-heading">
        <h2 id="footer-social-heading" class="section-title">Follow Us</h2>
        <ul class="link-list social-list">
          {socialLinks.map(({ href, label, Icon }) => (
            <li>
              <a href={href} target="_blank" rel="noreferrer noopener" aria-label={label}>
                <Icon className="social-icon" aria-hidden="true" />
                <span>{label}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid #e5e7eb;
    margin-top: 3rem;
  }

  .inner {
    max-width: 1120px;
    margin: 0 auto;
    padding: 2rem 1rem;
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
    color: #4b5563;
  }

  .brand-block {
    min-width: 220px;
  }

  .brand-name {
    margin: 0;
    font-weight: 600;
    color: #111827;
  }

  .brand-tagline {
    margin: 0.35rem 0 0;
  }

  .footer-nav {
    display: grid;
    grid-template-columns: repeat(2, minmax(140px, 1fr));
    gap: 2rem;
  }

  .section-title {
    margin: 0;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #111827;
  }

  .link-list {
    list-style: none;
    margin: 0.75rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .link-list a {
    color: #4b5563;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .link-list a:hover,
  .link-list a:focus-visible {
    color: #111827;
  }

  .social-list a {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  .social-icon {
    width: 1rem;
    height: 1rem;
  }

  @media (max-width: 640px) {
    .inner {
      flex-direction: column;
      gap: 1.5rem;
    }

    .footer-nav {
      width: 100%;
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
  }

  p {
    margin: 0;
  }
</style>
