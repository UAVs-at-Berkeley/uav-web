---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
	title?: string;
}

const { title = 'UAVs at Berkeley' } = Astro.props;
const isHomePage = Astro.url.pathname === '/';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<Navbar currentPath={Astro.url.pathname} />
		<main class={isHomePage ? 'home-main' : undefined}>
			<slot />
		</main>
		<Footer />
	</body>
</html>

<style is:global>
	:root {
		color-scheme: light;
	}

	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
	}

	main {
		max-width: 1120px;
		margin: 0 auto;
		padding: 1.25rem 1rem;
	}

	main.home-main {
		padding-top: 0;
	}

	h1,
	h2,
	h3 {
		line-height: 1.2;
	}

	section h2 {
		margin: 0 0 0.7rem;
	}
</style>
